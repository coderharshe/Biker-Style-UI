{
  "expo": {
    "name": "Velox",
    "slug": "motosphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "velox",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.harsh.velox",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Velox uses your location to discover nearby riders and navigate routes.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "To track your ride accurately and provide proximity alerts, Velox needs background location access.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.harsh.velox",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0B",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA8Ux064j0NKyJrcbXK1NMufKamdbEGLXA"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "output": "single"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://velox.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Velox to use your location.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#FF6B2C"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "minSdkVersion": 29,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "extraMavenRepos": [
              "https://maven.google.com"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/4668c693-fba4-4bad-b98c-dedc0878d69b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "origin": "https://velox.app/"
      },
      "eas": {
        "projectId": "4668c693-fba4-4bad-b98c-dedc0878d69b"
      }
    }
  }
}
